# App
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:3001
APP_VERSION=2.1.0

# PostgreSQL
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# ClickHouse
CLICKHOUSE_URL=http://default:PASSWORD@localhost:8123/pilot
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DB=pilot
CLICKHOUSE_REQUEST_TIMEOUT_MS=5000

# JWT
JWT_SECRET=replace_with_64_characters_or_more_secret_value_here_1234567890
JWT_EXPIRES_IN=15m

# Redis / queues
QUEUE_ENABLED=true
REDIS_URL=redis://localhost:6379

# Encryption AES-256 (64 hex chars)
ENCRYPTION_KEY=abcdefabcdefabcdefabcdefabcdefabcdefabcdefabcdefabcdefabcdefabcd

# Monitoring
METRICS_TOKEN=replace_with_secure_metrics_token
ADMIN_TOKEN=change_me_random_32_chars_admin
SENTRY_DSN=

# Python agents
ANTHROPIC_API_KEY=

# Google Ads
GOOGLE_CLIENT_ID=1234567890
GOOGLE_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_REDIRECT_URI=http://localhost:3000/api/v1/integrations/google-ads/oauth/callback
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_API_VERSION=v22

# WooCommerce
WOOCOMMERCE_WEBHOOK_SECRET=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_PRICE_ID=
STRIPE_GROWTH_PRICE_ID=
STRIPE_SCALE_PRICE_ID=
