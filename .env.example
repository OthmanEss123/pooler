# App
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:3001

# Supabase (obligatoire)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# ClickHouse (obligatoire) — URL complčte
CLICKHOUSE_URL=http://default:PASSWORD@localhost:8123/pilot
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DB=pilot

# JWT (obligatoire)
JWT_SECRET=
JWT_EXPIRES_IN=15m

# Redis (semaine 7)
REDIS_URL=redis://localhost:6379

# Encryption AES-256 — 64 chars hex (semaine 6)
ENCRYPTION_KEY=

# gRPC (semaine 11)
GRPC_PORT=50051