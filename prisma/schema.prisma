generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  OWNER
  ADMIN
  MEMBER
}

enum ApiKeyScope {
  FULL_ACCESS
  READ_ONLY
  INGEST
}

enum BillingPlan {
  STARTER
  GROWTH
  SCALE
}

enum BillingSubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  INCOMPLETE
  CANCELED
  UNPAID
}

enum EmailStatus {
  SUBSCRIBED
  UNSUBSCRIBED
  BOUNCED
  COMPLAINED
  PENDING
}

enum SegmentType {
  DYNAMIC
  STATIC
  GA4
}

enum OrderStatus {
  PENDING
  PAID
  FULFILLED
  CANCELLED
  REFUNDED
}

enum IntegrationType {
  WOOCOMMERCE
  GOOGLE_ANALYTICS
  GOOGLE_ADS
}

enum IntegrationStatus {
  ACTIVE
  DISCONNECTED
  ERROR
}

enum AdCampaignType {
  SEARCH
  SHOPPING
  PERFORMANCE_MAX
  DISPLAY
  VIDEO
}

enum AdCampaignStatus {
  ENABLED
  PAUSED
  REMOVED
}

model Tenant {
  id         String                    @id @default(cuid())
  name       String
  slug       String                    @unique
  isActive   Boolean                   @default(true)
  plan       BillingPlan               @default(STARTER)
  planStatus BillingSubscriptionStatus @default(ACTIVE)
  createdAt  DateTime                  @default(now())
  updatedAt  DateTime                  @updatedAt

  users               User[]
  refreshTokens       RefreshToken[]
  apiKeys             ApiKey[]
  memberships         Membership[]
  insights            Insight[]
  healthScores        CustomerHealthScore[]
  integrations        Integration[]
  adCampaigns         AdCampaign[]
  adAudiences         AdAudience[]
  billingSubscription  BillingSubscription?
  invitationTokens     InvitationToken[]

  @@map("tenants")
}

model User {
  id           String    @id @default(cuid())
  tenantId     String
  email        String    @unique
  passwordHash String
  firstName    String?
  lastName     String?
  role         UserRole  @default(MEMBER)
  isActive          Boolean   @default(true)
  emailVerified     Boolean   @default(false)
  mfaEnabled        Boolean   @default(false)
  mfaSecret         String?
  verifyToken       String?   @unique
  verifyTokenExpiry DateTime?
  lastLoginAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  refreshTokens RefreshToken[]
  memberships   Membership[]

  @@index([tenantId])
  @@index([tenantId, role])
  @@map("users")
}

model RefreshToken {
  id                String    @id @default(cuid())
  tenantId          String
  userId            String
  tokenHash         String    @unique
  tokenFamily       String
  expiresAt         DateTime
  revokedAt         DateTime?
  createdAt         DateTime  @default(now())
  replacedByTokenId String?
  userAgent         String?
  ipAddress         String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@index([tokenFamily])
  @@index([expiresAt])
  @@index([revokedAt])
  @@map("refresh_tokens")
}

model ApiKey {
  id         String      @id @default(cuid())
  tenantId   String
  name       String
  prefix     String
  keyHash    String      @unique
  scope      ApiKeyScope @default(FULL_ACCESS)
  lastUsedAt DateTime?
  expiresAt  DateTime?
  revokedAt  DateTime?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([prefix])
  @@index([expiresAt])
  @@index([revokedAt])
  @@map("api_keys")
}

model Membership {
  id        String   @id @default(uuid())
  tenantId  String
  userId    String
  role      UserRole @default(MEMBER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@index([userId])
  @@map("memberships")
}
model BillingSubscription {
  id                   String                    @id @default(cuid())
  tenantId             String                    @unique
  plan                 BillingPlan               @default(STARTER)
  status               BillingSubscriptionStatus @default(ACTIVE)
  stripeCustomerId     String?                   @unique
  stripeSubscriptionId String?                   @unique
  stripePriceId        String?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean                   @default(false)
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("billing_subscriptions")
}

model Contact {
  id       String @id @default(uuid())
  tenantId String

  email         String
  firstName     String?
  lastName      String?
  phone         String?
  sourceChannel String?
  properties    Json?

  emailStatus  EmailStatus              @default(PENDING)
  totalRevenue Decimal                  @default(0) @db.Decimal(12, 2)
  totalOrders  Int                      @default(0)

  firstOrderAt   DateTime?
  lastOrderAt    DateTime?
  subscribed     Boolean                  @default(true)
  unsubscribedAt DateTime?
  bouncedAt      DateTime?
  complainedAt   DateTime?

  healthScore CustomerHealthScore?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders           Order[]
  segmentMembers   SegmentMember[]
  adAudienceMembers AdAudienceMember[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([tenantId, emailStatus])
  @@index([tenantId, totalRevenue])
  @@index([tenantId, totalOrders])
  @@index([tenantId, firstOrderAt])
  @@index([tenantId, lastOrderAt])
}

model Order {
  id          String      @id @default(uuid())
  tenantId    String
  contactId   String
  externalId  String
  orderNumber String?
  status      OrderStatus @default(PENDING)
  totalAmount Decimal     @db.Decimal(12, 2)
  subtotal    Decimal?    @db.Decimal(12, 2)
  currency    String
  source      String      @default("manual")
  rawPayload  Json?
  placedAt    DateTime
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  contact Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  items   OrderItem[]

  @@unique([tenantId, externalId])
  @@index([tenantId])
  @@index([contactId])
  @@index([status])
  @@index([placedAt])
}

model OrderItem {
  id                String   @id @default(uuid())
  tenantId          String
  orderId           String
  externalId        String
  productId         String?
  productExternalId String?
  name              String
  sku               String?
  quantity          Int
  unitPrice         Decimal  @db.Decimal(12, 2)
  totalPrice        Decimal  @db.Decimal(12, 2)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@unique([tenantId, externalId])
  @@index([tenantId])
  @@index([orderId])
  @@index([productId])
}

model Segment {
  id       String @id @default(uuid())
  tenantId String

  name        String
  description String?
  type        SegmentType
  conditions  Json

  contactCount Int       @default(0)
  lastSyncAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members     SegmentMember[]
  adAudiences AdAudience[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([tenantId, type])
}

model SegmentMember {
  segmentId String
  contactId String
  addedAt   DateTime @default(now())

  segment Segment @relation(fields: [segmentId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@id([segmentId, contactId])
  @@index([contactId])
}

model Product {
  id            String   @id @default(uuid())
  tenantId      String
  externalId    String
  name          String
  sku           String?
  price         Decimal  @db.Decimal(12, 2)
  imageUrl      String?
  category      String?
  tags          String[] @default([])
  stockQuantity Int?
  lowStockAlert Int?
  trackStock    Boolean  @default(false)
  isActive      Boolean  @default(true)
  rawPayload    Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  orderItems OrderItem[]

  @@unique([tenantId, externalId])
  @@index([tenantId])
  @@index([tenantId, category])
  @@index([tenantId, isActive])
  @@index([tenantId, trackStock])
  @@map("products")
}

enum InsightType {
  ANOMALY
  AD_WASTE
  REVENUE_FORECAST
  SEGMENT_OPPORTUNITY
  EMAIL_PERFORMANCE
  PRODUCT_INTELLIGENCE
}

enum RfmSegment {
  CHAMPION
  LOYAL
  POTENTIAL
  NEW
  AT_RISK
  CANT_LOSE
  LOST
}

model Insight {
  id          String      @id @default(cuid())
  tenantId    String
  type        InsightType
  title       String
  description String?
  data        Json?
  impact      Decimal?    @db.Decimal(12, 2)
  isRead      Boolean     @default(false)
  expiresAt   DateTime?
  createdAt   DateTime    @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, type])
  @@index([createdAt])
}

model CustomerHealthScore {
  id             String     @id @default(cuid())
  tenantId       String
  contactId      String     @unique
  segment        RfmSegment
  rfmScore       Int
  recencyScore   Int
  frequencyScore Int
  monetaryScore  Int
  churnRisk      Float
  predictedLtv   Float?
  calculatedAt   DateTime   @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, segment])
  @@index([calculatedAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String?
  action    String
  entity    String
  entityId  String?
  metadata  Json
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@index([entity, entityId])
}
model Integration {
  id          String            @id @default(cuid())
  tenantId    String
  type        IntegrationType
  status      IntegrationStatus @default(DISCONNECTED)
  credentials String?
  metadata    Json?
  lastSyncAt  DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, type])
  @@index([tenantId])
  @@index([status])
  @@map("integrations")
}

model AdCampaign {
  id               String            @id @default(cuid())
  tenantId         String
  externalId       String
  name             String
  type             AdCampaignType
  status           AdCampaignStatus
  budgetDaily      Decimal?          @db.Decimal(18, 2)
  spend            Decimal           @default(0) @db.Decimal(18, 2)
  impressions      Int               @default(0)
  clicks           Int               @default(0)
  conversions      Decimal           @default(0) @db.Decimal(18, 2)
  conversionValue  Decimal           @default(0) @db.Decimal(18, 2)
  roas             Decimal           @default(0) @db.Decimal(18, 4)
  syncedAt         DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  audiences        AdAudience[]

  @@unique([tenantId, externalId])
  @@index([tenantId])
  @@index([status])
}

model AdAudience {
  id            String              @id @default(cuid())
  tenantId      String
  adCampaignId  String?
  segmentId     String?
  externalId    String?
  name          String
  memberCount   Int                 @default(0)
  lastSyncAt    DateTime?
  createdAt     DateTime            @default(now())

  tenant        Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  adCampaign    AdCampaign?         @relation(fields: [adCampaignId], references: [id], onDelete: SetNull)
  segment       Segment?            @relation(fields: [segmentId], references: [id], onDelete: SetNull)
  members       AdAudienceMember[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([adCampaignId])
  @@index([segmentId])
}

model InvitationToken {
  id        String    @id @default(cuid())
  tenantId  String
  email     String
  role      UserRole  @default(MEMBER)
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([expiresAt])
  @@map("invitation_tokens")
}

model AdAudienceMember {
  audienceId    String
  contactId     String
  addedAt       DateTime            @default(now())

  audience      AdAudience          @relation(fields: [audienceId], references: [id], onDelete: Cascade)
  contact       Contact             @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@id([audienceId, contactId])
  @@index([contactId])
}







